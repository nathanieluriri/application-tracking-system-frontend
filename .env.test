# Test environment. MONGODB_URI / DB_NAME are overridden at runtime by the
# in-memory Mongo server (see tests/helpers/db.ts).
ENV=test
MONGODB_URI=mongodb://localhost:27017
DB_NAME=ats_test
SECRET_KEY=test-secret-key-do-not-use-in-prod
SESSION_SECRET_KEY=test-session-secret
ACCESS_TOKEN_MAX_AGE_SECONDS=86400
REFRESH_TOKEN_MAX_AGE_SECONDS=2592000
ACCESS_TOKEN_TTL_DAYS=10
CORS_ORIGINS=http://localhost:3000
ROLE_RATE_LIMITS=anonymous:20/minute,user:80/minute,admin:140/minute
DEBUG_INCLUDE_ERROR_DETAILS=true
JOB_BACKEND=inline
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./.storage-test
EMAIL_TRANSPORT=console
EMAIL_FROM_EMAIL=no-reply@ats.local
EMAIL_SENDER_NAME=ATS
EMAIL_QUEUE_ENABLED=true
PAYMENT_DEFAULT_PROVIDER=stripe
